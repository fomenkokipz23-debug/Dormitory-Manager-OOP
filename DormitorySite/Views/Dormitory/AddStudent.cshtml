@using DormitorySite.Models
@model Student

@{
    ViewData["Title"] = "Реєстрація студента";
}

<div class="container mt-4" style="max-width: 500px;">
    <div class="card shadow-sm p-4 border-0 rounded-4">
        <h2 class="mb-4 fw-bold text-primary text-center">
            <i class="bi bi-person-plus"></i> Реєстрація студента
        </h2>

        @* Загальне сповіщення про помилки (наприклад, якщо стать не співпадає) *@
        @if (!ViewData.ModelState.IsValid)
        {
            <div class="alert alert-danger border-0 shadow-sm mb-4">
                <i class="bi bi-exclamation-octagon-fill me-2"></i>
                @Html.ValidationSummary(true, "")
            </div>
        }

        @* Використовуємо Tag Helper для форми (автоматично додає захист від CSRF) *@
        <form asp-action="AddStudent" method="post">
            
            @* ПІБ *@
            <div class="mb-3">
                <label class="form-label small fw-bold text-muted">ПІБ СТУДЕНТА:</label>
                @* asp-for автоматично згенерує id, name та підтягне value з моделі *@
                <input asp-for="FullName" class="form-control" placeholder="Прізвище Ім'я По батькові" />
                @* Цей рядок автоматично покаже помилку з нашого Student.cs, якщо поле порожнє *@
                <span asp-validation-for="FullName" class="text-danger small fw-bold"></span>
            </div>

            @* ОБРАННЯ КІМНАТИ *@
            <div class="mb-3">
                <label class="form-label small fw-bold text-muted">ОБЕРІТЬ КІМНАТУ</label>
                <select asp-for="RoomNumber" id="RoomNumber" class="form-select bg-light" onchange="calculatePrice()">
                    <option value="">-- Оберіть номер кімнати --</option>
                    @if (ViewBag.Rooms != null)
                    {
                        foreach (var room in (List<Room>)ViewBag.Rooms)
                        {
                            bool isAvailable = room.State.CanAssignStudent(room.Students.Count);
                            string genderInfo = room.Students.Any() ? $" ({room.Students.First().Gender})" : " (Порожня)";

                            <option value="@room.Number" 
                                    selected="@(room.Number == ViewBag.SelectedRoom)"
                                    disabled="@(!isAvailable)"
                                    data-room-type="@(room.Number.ToString().StartsWith("1") ? "Standard" : (room.Number.ToString().StartsWith("2") ? "Discount" : "Luxury"))"
                                    class="@(isAvailable ? "" : "text-danger")">
                                №@room.Number @genderInfo — @room.Students.Count/4 місць
                            </option>
                        }
                    }
                </select>
                <span asp-validation-for="RoomNumber" class="text-danger small fw-bold"></span>
            </div>

            @* ПЕРІОД ОПЛАТИ *@
            <div class="mb-3">
                <label class="form-label small fw-bold text-muted">ПЕРІОД ОПЛАТИ:</label>
                <select asp-for="PaidMonths" id="PaidMonths" class="form-select bg-light" onchange="calculatePrice()">
                    <option value="0">Ще не оплачено (Борг)</option>
                    <option value="1">1 місяць</option>
                    <option value="5">5 місяців (Семестр)</option>
                    <option value="10">10 місяців (Рік)</option>
                </select>
            </div>

            @* БЛОК РОЗРАХУНКУ ВАРТОСТІ *@
            <div class="alert alert-info border-0 shadow-sm mb-4 py-2" id="priceAlert" style="display: none;">
                <div class="d-flex justify-content-between align-items-center">
                    <small class="fw-bold"><i class="bi bi-calculator me-1"></i> ДО ОПЛАТИ:</small>
                    <span id="totalPrice" class="fw-bold fs-5 text-primary">0 грн</span>
                </div>
            </div>

            @* СТАТЬ ТА КУРС *@
            <div class="row">
                <div class="col-md-6 mb-3">
                    <label class="form-label small fw-bold text-muted">СТАТЬ:</label>
                    <select asp-for="Gender" class="form-select bg-light">
                        <option value="Чоловіча">Чоловіча</option>
                        <option value="Жіноча">Жіноча</option>
                    </select>
                    <span asp-validation-for="Gender" class="text-danger small fw-bold"></span>
                </div>
                <div class="col-md-6 mb-3">
                    <label class="form-label small fw-bold text-muted">КУРС:</label>
                    <input asp-for="Course" class="form-control" />
                    <span asp-validation-for="Course" class="text-danger small fw-bold"></span>
                </div>
            </div>

            @* ДАТИ *@
            <div class="row">
                <div class="col-md-6 mb-3">
                    <label class="form-label small fw-bold text-muted">ДАТА ЗАСЕЛЕННЯ:</label>
                    <input asp-for="SettlementDate" type="date" class="form-control" />
                </div>
                <div class="col-md-6 mb-3">
                    <label class="form-label small fw-bold text-muted">ДАТА ВИСЕЛЕННЯ:</label>
                    <input asp-for="DepartureDate" type="date" class="form-control" />
                </div>
            </div>

            <div class="d-grid gap-2 mt-2">
                <button type="submit" class="btn btn-success shadow-sm py-2 fw-bold rounded-3">
                    <i class="bi bi-check-circle me-1"></i> ЗАТВЕРДИТИ ПОСЕЛЕННЯ
                </button>
                <a href="@Url.Action("Index", "Dormitory")" class="btn btn-link text-muted btn-sm text-decoration-none">Скасувати</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @* Цей скрипт підключає клієнтську валідацію jQuery (працює миттєво без перезавантаження сторінки) *@
    <partial name="_ValidationScriptsPartial" />

    <script>
        function calculatePrice() {
            const roomSelect = document.getElementById("RoomNumber");
            const monthsSelect = document.getElementById("PaidMonths");
            const priceAlert = document.getElementById("priceAlert");
            const priceDisplay = document.getElementById("totalPrice");

            const months = parseInt(monthsSelect.value);
            const selectedOption = roomSelect.options[roomSelect.selectedIndex];
            
            if (!selectedOption || selectedOption.value === "" || months === 0) {
                priceAlert.style.display = "none";
                return;
            }

            const roomType = selectedOption.getAttribute("data-room-type");
            let dailyRate = 200; // Standard

            if (roomType === "Discount") dailyRate = 80;
            if (roomType === "Luxury") dailyRate = 500;

            const total = dailyRate * 30 * months;
            
            priceDisplay.innerText = total.toLocaleString() + " грн";
            priceAlert.style.display = "block";
        }

        document.addEventListener("DOMContentLoaded", calculatePrice);
    </script>
}