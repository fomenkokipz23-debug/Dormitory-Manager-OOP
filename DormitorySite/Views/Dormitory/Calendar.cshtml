@{
    ViewData["Title"] = "Календар руху мешканців";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold text-primary">
            <i class="bi bi-calendar3"></i> Графік заселень та виселень
        </h2>
        @* Трохи стилізували легенду, щоб вона виглядала як панель керування *@
        <div class="text-muted border px-3 py-2 rounded-3 bg-light shadow-sm small fw-bold">
            <span class="badge bg-success me-1"><i class="bi bi-box-arrow-in-right"></i></span> Заселення
            <span class="badge bg-danger ms-3 me-1"><i class="bi bi-box-arrow-right"></i></span> Виселення
        </div>
    </div>

    <div class="card shadow-sm border-0 bg-white p-4 rounded-4">
        <div id='calendar'></div>
    </div>
</div>

@section Scripts {
    <script src='https://cdn.jsdelivr.net/npm/fullcalendar@6.1.8/index.global.min.js'></script>
    <script src='https://cdn.jsdelivr.net/npm/fullcalendar@6.1.8/locales-all.global.min.js'></script>
    
    <script>
      document.addEventListener('DOMContentLoaded', function() {
        var calendarEl = document.getElementById('calendar');
        
        var calendar = new FullCalendar.Calendar(calendarEl, {
          initialView: 'dayGridMonth',
          locale: 'uk',
          firstDay: 1,
          headerToolbar: {
            left: 'prev,next today',
            center: 'title',
            right: 'dayGridMonth,timeGridWeek'
          },
          buttonText: {
            today: 'Сьогодні',
            month: 'Місяць',
            week: 'Тиждень'
          },
          
          // ПРОФЕСІЙНИЙ ПІДХІД: Обробка помилок завантаження подій
          events: {
              url: '@Url.Action("GetCalendarEvents", "Dormitory")',
              failure: function() {
                  alert('⚠️ Помилка завантаження даних! Можливо, ваша сесія закінчилася. Будь ласка, оновіть сторінку або увійдіть знову.');
              }
          },
          
          eventClick: function(info) {
             // Запобігаємо стандартній поведінці браузера
             info.jsEvent.preventDefault(); 
             alert("Деталі:\n" + info.event.title + "\nДата: " + info.event.start.toLocaleDateString('uk-UA'));
          },
          height: 'auto'
        });
        
        calendar.render();
      });
    </script>
}