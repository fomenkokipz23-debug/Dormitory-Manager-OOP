@model List<string>

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold text-dark"><i class="bi bi-journal-text"></i> Журнал подій системи</h2>
    </div>

    <div class="card shadow-sm border-0 rounded-4 overflow-hidden">
        <div class="card-body p-0">
            <div class="list-group list-group-flush">
                @if (Model != null && Model.Any())
                {
                    @foreach (var log in Model.AsEnumerable().Reverse()) // Останні події зверху
                    {
                        <div class="list-group-item list-group-item-action py-3">
                            <div class="d-flex w-100 justify-content-between">
                                <p class="mb-1">@log</p>
                            </div>
                        </div>
                    }
                }
                else
                {
                    <div class="p-5 text-center text-muted">
                        <i class="bi bi-info-circle display-4"></i>
                        <p class="mt-3">Журнал порожній. Заселіть когось, щоб з'явилися записи.</p>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

<style>
    .list-group-item { border-left: 5px solid #6a3f6e; transition: all 0.2s; }
    .list-group-item:hover { background-color: #f8f9fa; transform: translateX(5px); }
</style>